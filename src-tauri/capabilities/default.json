{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "opener:default",
    "dialog:allow-open",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:scope-appdata-recursive",
    "fs:scope-home-recursive"
  ]
}
